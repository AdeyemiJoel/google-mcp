# Transport mode: "stdio" (default) or "http"
GDRIVE_MCP_TRANSPORT=stdio

# HTTP bind address (only used when transport=http)
GDRIVE_MCP_HTTP_ADDR=127.0.0.1:3000

# Path to Google OAuth2 client credentials JSON file
GDRIVE_MCP_CREDENTIALS=client_secret.json

# Path to persist OAuth2 token cache
GDRIVE_MCP_TOKEN_CACHE=~/.gdrive-mcp-token.json

# Log level: error, warn, info, debug, trace
GDRIVE_MCP_LOG_LEVEL=info
